{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "jcodemunch: watch (index)",
      "type": "shell",
      "command": "uvx",
      "args": ["--with", "jcodemunch-mcp[watch]", "jcodemunch-mcp", "watch", "${workspaceFolder}"],
      "problemMatcher": [],
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "dedicated",
        "showReuseMessage": false,
        "clear": false
      },
      "runOptions": {
        "runOn": "folderOpen"
      }
    }
  ]
}
