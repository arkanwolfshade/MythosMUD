{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["vite.userConfig.ts", "tests/e2e/runtime/global-setup.ts", "tests/e2e/runtime/global-teardown.ts"],
  "project": ["src/**/*.{ts,tsx,js,jsx}", "tests/**/*.ts"],
  "ignoreDependencies": ["@stoplight/spectral-cli", "markdownlint-cli", "patch-package", "stylelint", "cross-env"],
  "treatConfigHintsAsErrors": false,
  "rules": {
    "exports": "off",
    "types": "off",
    "files": "off",
    "devDependencies": "error",
    "dependencies": "error",
    "unlisted": "error"
  }
}
