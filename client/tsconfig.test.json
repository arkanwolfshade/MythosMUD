{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["vitest/globals", "@testing-library/jest-dom/vitest", "node", "vite/client"],
    "noEmit": false,
    "allowImportingTsExtensions": false
  },
  "include": [
    "src/vite-env.d.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/**/*TestFixtures.ts",
    "src/test/**/*"
  ],
  "exclude": []
}
